{
  "openapi": "3.0.1",
  "info": {
    "title": "LEON - Conformity Matrix Analyzer",
    "description": "API d'analyse de matrices de conformite FNR pour LEON Copilot Studio. Fonctionnalites: analyser ODS/XLSX -> rapport PDF ou Excel, comparer matrices, dataset Power BI. Authentification: cle API Azure Function en query string (parametre 'code').",
    "version": "2.1.0"
  },
  "servers": [
    {
      "url": "https://leon-spec-gbexcnefdmakfpdg.francecentral-01.azurewebsites.net",
      "description": "Production Azure Function"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/conformity": {
      "post": {
        "summary": "Analyser une matrice de conformite -> rapport PDF avec camembert",
        "description": "Uploader une matrice de conformite (ODS ou XLSX) et recevoir un rapport PDF complet avec diagramme camembert, liste des exigences OK/NOK/NA, et analyse approfondie des reponses OK.",
        "operationId": "conformityPdf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConformityRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analyse reussie - rapport PDF genere",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConformityFileResponse" }
              }
            }
          },
          "400": {
            "description": "Requete invalide",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Erreur interne",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/conformity-excel": {
      "post": {
        "summary": "Generer un rapport Excel colore depuis une matrice de conformite",
        "description": "Uploader une matrice de conformite (ODS ou XLSX) et recevoir un rapport Excel avec 3 feuilles: Summary (statistiques + camembert), All Items (exigences colorees par statut), Analyse approfondie OK (points d'attention).",
        "operationId": "conformityExcel",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConformityRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rapport Excel genere",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConformityFileResponse" }
              }
            }
          },
          "400": {
            "description": "Requete invalide",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Erreur interne",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/conformity-compare": {
      "post": {
        "summary": "Comparer plusieurs matrices de conformite",
        "description": "Comparer 2 matrices ou plus. Retourne les changements de statut, les exigences manquantes, un graphique comparatif et un rapport texte.",
        "operationId": "conformityCompare",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompareRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comparaison reussie",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CompareResponse" }
              }
            }
          },
          "400": {
            "description": "Requete invalide",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Erreur interne",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/conformity-powerbi": {
      "post": {
        "summary": "Generer un dataset Power BI depuis une matrice",
        "description": "Genere un JSON compatible Power BI avec 3 tables (StatusSummary, Items, Inconsistencies) et 7 graphiques suggeres.",
        "operationId": "conformityPowerBi",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PowerBIRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset Power BI genere",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PowerBIResponse" }
              }
            }
          },
          "400": {
            "description": "Requete invalide",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Erreur interne",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Verifier l'etat de sante de l'API",
        "description": "Endpoint de health check. Retourne le statut de l'API et les services connectes.",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "API fonctionnelle",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "code",
        "description": "Cle API de la Function Azure (host key). Passee en query string: ?code=VOTRE_CLE"
      }
    },
    "schemas": {
      "ConformityRequest": {
        "type": "object",
        "required": ["fileName"],
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Nom du fichier avec extension (.ods ou .xlsx). Exemple: DM12F_Conformity_Matrix.ods"
          },
          "fileContent": {
            "type": "string",
            "format": "byte",
            "description": "Contenu du fichier encode en base64. Optionnel si fileUrl est fourni."
          },
          "fileUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL du fichier a telecharger (SharePoint, OneDrive). Alternative a fileContent."
          }
        }
      },
      "CompareRequest": {
        "type": "object",
        "required": ["fileNames"],
        "properties": {
          "fileNames": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Liste des noms de fichiers a comparer (minimum 2). Les fichiers doivent etre deja uploades.",
            "minItems": 2
          }
        }
      },
      "PowerBIRequest": {
        "type": "object",
        "required": ["fileName"],
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Nom du fichier matrice (.ods ou .xlsx)"
          },
          "fileContent": {
            "type": "string",
            "format": "byte",
            "description": "Contenu du fichier encode en base64 (optionnel)"
          },
          "fileUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL du fichier a telecharger (alternative a fileContent)"
          }
        }
      },
      "ConformityFileResponse": {
        "type": "object",
        "description": "Reponse standard pour les endpoints PDF et Excel",
        "properties": {
          "answer": {
            "type": "string",
            "description": "Resume en francais destine a l'utilisateur. Contient le nombre total d'exigences, les comptes OK/NOK/NA et les points d'attention detectes."
          },
          "status": {
            "type": "string",
            "description": "Statut de la reponse: 'answered' si succes, 'error' si echec."
          },
          "confidence": {
            "type": "string",
            "description": "Niveau de confiance: HIGH"
          },
          "fileName": {
            "type": "string",
            "description": "Nom du fichier analyse"
          },
          "analysis": {
            "type": "object",
            "description": "Analyse complete (items, stats, okDeepFindings, chartBase64, summary, etc.)",
            "properties": {
              "summary": {
                "type": "object",
                "properties": {
                  "total": { "type": "integer" },
                  "ok": { "type": "integer" },
                  "nok": { "type": "integer" },
                  "na": { "type": "integer" },
                  "empty": { "type": "integer" },
                  "okDeepFindings": { "type": "integer" }
                }
              },
              "chartBase64": {
                "type": "string",
                "description": "Camembert de repartition (base64 PNG ou SVG)"
              }
            }
          },
          "reportPdf": {
            "type": "string",
            "format": "byte",
            "description": "Rapport PDF complet encode en base64. A decoder et fournir en telechargement."
          },
          "reportExcel": {
            "type": "string",
            "format": "byte",
            "description": "Fichier Excel encode en base64 (3 feuilles). A decoder et fournir en telechargement."
          }
        }
      },
      "CompareResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string",
            "description": "Resume en francais destine a l'utilisateur."
          },
          "status": {
            "type": "string",
            "description": "Statut: 'answered' si succes, 'error' si echec."
          },
          "totalCompared": {
            "type": "integer",
            "description": "Nombre total d'exigences comparees entre les matrices."
          },
          "totalChanges": {
            "type": "integer",
            "description": "Nombre d'exigences ayant change de statut."
          },
          "totalMissing": {
            "type": "integer",
            "description": "Nombre d'exigences presentes dans certaines matrices mais absentes d'autres."
          },
          "chartBase64": {
            "type": "string",
            "description": "Graphique a barres comparatif (base64)."
          },
          "reportText": {
            "type": "string",
            "description": "Rapport texte detaille de la comparaison."
          }
        }
      },
      "PowerBIResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string",
            "description": "Message de confirmation en francais."
          },
          "status": {
            "type": "string",
            "description": "Statut: 'answered' si succes, 'error' si echec."
          },
          "powerbi": {
            "type": "object",
            "description": "Dataset Power BI complet avec 3 tables et configuration dashboard."
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Statut de l'API: 'healthy' si tout fonctionne."
          },
          "version": {
            "type": "string",
            "description": "Version de l'API deployee."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string",
            "description": "Message d'erreur en francais destine a l'utilisateur."
          },
          "status": {
            "type": "string",
            "description": "Toujours 'error' en cas d'erreur."
          }
        }
      }
    }
  }
}
